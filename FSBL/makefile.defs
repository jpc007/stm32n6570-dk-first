################################################################################
# Extra HAL sources not generated by CubeMX (bug workaround)
# This file is included by Debug/makefile via "-include ../makefile.defs"
# and is NEVER overwritten by CubeIDE code generation.
#
# If CubeIDE eventually adds these files to subdir.mk, the conditionals
# below will detect them and skip the duplicate additions.
################################################################################

HAL_SRC_DIR = C:/Develop/Software/CubeIdeWorkspace/STM32N657/first/Drivers/STM32N6xx_HAL_Driver/Src

HAL_EXTRA_CFLAGS = \
	-mcpu=cortex-m55 -std=gnu11 -g3 \
	-DDEBUG -DUSE_HAL_DRIVER -DSTM32N657xx -DUSE_FULL_LL_DRIVER \
	-c \
	-I../Core/Inc \
	-I../../Drivers/STM32N6xx_HAL_Driver/Inc \
	-I../../Drivers/CMSIS/Device/ST/STM32N6xx/Include \
	-I../../Drivers/STM32N6xx_HAL_Driver/Inc/Legacy \
	-I../../Drivers/STM32N6xx_HAL_Driver/Src \
	-I../../Drivers/CMSIS/Include \
	-O0 -ffunction-sections -fdata-sections -Wall \
	-fstack-usage -fcyclomatic-complexity -mcmse \
	-MMD -MP --specs=nano.specs \
	-mfpu=fpv5-d16 -mfloat-abi=hard -mthumb

# --- stm32n6xx_hal_ramcfg ---
ifeq ($(filter %stm32n6xx_hal_ramcfg.o,$(OBJS)),)
OBJS += ./Drivers/STM32N6xx_HAL_Driver/stm32n6xx_hal_ramcfg.o
C_DEPS += ./Drivers/STM32N6xx_HAL_Driver/stm32n6xx_hal_ramcfg.d
USER_OBJS += ./Drivers/STM32N6xx_HAL_Driver/stm32n6xx_hal_ramcfg.o

Drivers/STM32N6xx_HAL_Driver/stm32n6xx_hal_ramcfg.o: $(HAL_SRC_DIR)/stm32n6xx_hal_ramcfg.c
	arm-none-eabi-gcc "$<" $(HAL_EXTRA_CFLAGS) -MF"$(@:%.o=%.d)" -MT"$@" -o "$@"
endif

# --- stm32n6xx_hal_rif ---
ifeq ($(filter %stm32n6xx_hal_rif.o,$(OBJS)),)
OBJS += ./Drivers/STM32N6xx_HAL_Driver/stm32n6xx_hal_rif.o
C_DEPS += ./Drivers/STM32N6xx_HAL_Driver/stm32n6xx_hal_rif.d
USER_OBJS += ./Drivers/STM32N6xx_HAL_Driver/stm32n6xx_hal_rif.o

Drivers/STM32N6xx_HAL_Driver/stm32n6xx_hal_rif.o: $(HAL_SRC_DIR)/stm32n6xx_hal_rif.c
	arm-none-eabi-gcc "$<" $(HAL_EXTRA_CFLAGS) -MF"$(@:%.o=%.d)" -MT"$@" -o "$@"
endif
