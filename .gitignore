# Build outputs
**/Debug/
**/Release/

# Eclipse / CubeIDE project-specific
.settings/
.metadata/
.mxproject

# VS Code — include workspace configs, exclude machine-specific
.vscode/*
!.vscode/README.md
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/c_cpp_properties.json

# Object files
*.o
*.d
*.elf
*.bin
*.hex
*.map
*.list

# Analysis / diagnostic notes (generated during debug sessions)
ANALYSE_PROJET_FIRST.md
DIAGNOSTIC_HARD_FAULT.md
INTEGRATION_LVGL.md

# Third-party / external libraries (too large for git)
ThirdParty/
Middlewares/
